{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TeacherEase Parent Companion",
  "version": "0.1.4",
  "identifier": "dev.autumnfallenwang.teacherease-parent-companion",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "TeacherEase Parent Companion",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "nsis", "app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM4OURDRTRCOEIwOTdFMTIKUldRU2ZnbUxTODZkT0pXMnlCYTd0UURRMWpubm1MWHBRSVpqb01kK0U1M25KOGNmOS9RNnFGM1AK",
      "endpoints": [
        "https://github.com/autumnfallenwang/teacherease-parent-companion/releases/latest/download/latest.json"
      ]
    }
  }
}
