# ============================================================================
# .env.example — DEV-ONLY template for sandbox POCs and live e2e tests
# ============================================================================
#
# The shipped desktop app does NOT read this file or any other .env at runtime.
# All user configuration in the installed app flows through the Settings UI
# into SQLite / OS keychain. See docs/design-plan.md "Q13 — Configuration
# storage" for the full architecture.
#
# This template exists ONLY so a developer can:
#   1. Copy it to sandbox/.env (NOT the repo root)
#   2. Fill in real values
#   3. Use it from throwaway scripts under sandbox/ (POCs, live e2e tests)
#
# sandbox/ is gitignored. A real .env at the repo root would be blocked by
# the pre-tool hook AND the commit-secrets hook — on purpose.
#
# See sandbox/README.md for what belongs in sandbox/ and the workflow for
# promoting cleaned artifacts (like scrubbed HTML fixtures) into the repo.
# ============================================================================


# --- TeacherEase portal (per child, per school) ----------------------------
# TeacherEase uses per-school subdomains. The URL path templates are constants
# baked into scraper/constants.ts; only the HOST varies per school.
TEACHEREASE_BASE_URL=https://school.example.teacherease.com
TEACHEREASE_USERNAME=test@example.com
TEACHEREASE_PASSWORD=hunter2


# --- Gating for live integration tests --------------------------------------
# Set to 1 ONLY when you deliberately want a test to hit the real portal.
# Never set in CI. Tests that read this should fail loudly if it's unset
# rather than silently mocking something.
TEACHEREASE_LIVE=0


# --- Optional: SMTP for email-reports POC -----------------------------------
# Only needed for scripts that test the optional email feature (design-plan Q4).
# In the shipped app these come from Settings → Advanced → Email, NOT from env.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=test@example.com
SMTP_PASSWORD=hunter2
SMTP_FROM=test@example.com
SMTP_TO=test@example.com
