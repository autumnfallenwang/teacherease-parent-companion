{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!node_modules",
      "!dist",
      "!.next",
      "!src-tauri",
      "!out",
      "!coverage",
      "!tests/fixtures"
    ]
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  },
  "linter": {
    "enabled": true,
    "domains": {
      "test": "recommended"
    },
    "rules": {
      "recommended": true,

      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "noUnusedFunctionParameters": "warn",
        "noConstAssign": "error",
        "noPrecisionLoss": "error",
        "noUndeclaredVariables": "error",
        "noInvalidUseBeforeDeclaration": "error",
        "noSelfAssign": "error",
        "noSwitchDeclarations": "error",
        "noVoidTypeReturn": "error",
        "useImportExtensions": "off"
      },

      "suspicious": {
        "noExplicitAny": "warn",
        "noImplicitAnyLet": "warn",
        "noDoubleEquals": "error",
        "noDebugger": "error",
        "noConsole": {
          "level": "warn",
          "options": {
            "allow": ["error", "warn", "info"]
          }
        },
        "noFallthroughSwitchClause": "error",
        "noRedeclare": "error",
        "noShadowRestrictedNames": "error",
        "noEmptyBlockStatements": "warn",
        "noEvolvingTypes": "warn",
        "noThenProperty": "error",
        "noVar": "error",
        "useAwait": "error",
        "useErrorMessage": "error",
        "useIsArray": "error"
      },

      "complexity": {
        "noForEach": "warn",
        "noStaticOnlyClass": "error",
        "noUselessCatch": "error",
        "noUselessConstructor": "error",
        "noUselessEmptyExport": "error",
        "noUselessTernary": "error",
        "noUselessTypeConstraint": "error",
        "useOptionalChain": "error",
        "useFlatMap": "warn",
        "useArrowFunction": "warn",
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": { "maxAllowedComplexity": 25 }
        }
      },

      "performance": {
        "noAccumulatingSpread": "warn",
        "noDelete": "warn",
        "noBarrelFile": "warn"
      },

      "security": {
        "noGlobalEval": "error",
        "noSecrets": "error"
      },

      "style": {
        "useConst": "error",
        "useTemplate": "error",
        "useExportType": "error",
        "useImportType": "error",
        "useNodejsImportProtocol": "error",
        "useSingleVarDeclarator": "error",
        "useDefaultParameterLast": "error",
        "useExponentiationOperator": "error",
        "useSelfClosingElements": "error",
        "useShorthandAssign": "error",
        "useThrowNewError": "error",
        "useThrowOnlyError": "error",
        "noNonNullAssertion": "warn",
        "noNegationElse": "warn",
        "noNestedTernary": "error",
        "noCommonJs": "error",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "@tauri-apps/api": "Import Tauri APIs through src/lib/ipc.ts, not directly. See design-plan.md 'Forward compatibility'.",
              "@tauri-apps/api/core": "Import Tauri APIs through src/lib/ipc.ts, not directly. See design-plan.md 'Forward compatibility'.",
              "@tauri-apps/api/event": "Import Tauri APIs through src/lib/ipc.ts, not directly. See design-plan.md 'Forward compatibility'.",
              "@tauri-apps/api/window": "Import Tauri APIs through src/lib/ipc.ts, not directly. See design-plan.md 'Forward compatibility'.",
              "@tauri-apps/plugin-sql": "Import through src/lib/ipc.ts — keeps React free of platform imports so business logic is portable.",
              "@tauri-apps/plugin-notification": "Import through src/lib/ipc.ts — keeps React free of platform imports so business logic is portable.",
              "@tauri-apps/plugin-autostart": "Import through src/lib/ipc.ts — keeps React free of platform imports so business logic is portable.",
              "@tauri-apps/plugin-updater": "Import through src/lib/ipc.ts — keeps React free of platform imports so business logic is portable.",
              "@tauri-apps/plugin-process": "Import through src/lib/ipc.ts — keeps React free of platform imports so business logic is portable.",
              "@tauri-apps/plugin-store": "Import through src/lib/ipc.ts — keeps React free of platform imports so business logic is portable.",
              "@tauri-apps/plugin-log": "Import through src/lib/ipc.ts — use log(), logWarning(), logErr() wrappers.",
              "@tauri-apps/plugin-http": "Import through src/lib/ipc.ts — use the tauriFetch wrapper. Scraper modules take FetchImpl as an injected parameter."
            }
          }
        },
        "useFilenamingConvention": {
          "level": "error",
          "options": { "requireAscii": true, "filenameCases": ["kebab-case", "export"] }
        },
        "useNamingConvention": {
          "level": "warn",
          "options": {
            "strictCase": false,
            "conventions": [
              { "selector": { "kind": "function" }, "formats": ["camelCase", "PascalCase"] },
              {
                "selector": { "kind": "variable" },
                "formats": ["camelCase", "CONSTANT_CASE", "PascalCase"]
              },
              { "selector": { "kind": "typeLike" }, "formats": ["PascalCase"] },
              {
                "selector": { "kind": "objectLiteralProperty" },
                "formats": ["camelCase", "snake_case", "CONSTANT_CASE", "PascalCase"]
              },
              { "selector": { "kind": "typeProperty" }, "formats": ["camelCase", "snake_case"] }
            ]
          }
        }
      },

      "nursery": {
        "noFloatingPromises": "error",
        "noShadow": "warn",
        "useAwaitThenable": "off",
        "useErrorCause": "warn"
      }
    }
  },
  "assist": {
    "enabled": true
  },
  "overrides": [
    {
      "includes": ["src/lib/ipc.ts", "src/lib/notify/os-channel.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    },
    {
      "includes": ["src/app/(shell)/**"],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.test.ts", "tests/**"],
      "linter": {
        "rules": {
          "security": {
            "noSecrets": "off"
          },
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    },
    {
      "includes": ["**/components/ui/**"],
      "linter": {
        "rules": {
          "security": {
            "noSecrets": "off"
          }
        }
      }
    }
  ]
}
